generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Show {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  episodes        Episode[]
  speakers        Speaker[]
  stagingEpisodes StagingEpisode[]
}

model Episode {
  id             Int      @id @default(autoincrement())
  showId         Int
  season         Int
  episodeNumber  Int
  airDate        DateTime?
  productionCode String    @unique
  title          String
  show           Show      @relation(fields: [showId], references: [id])
  clips          Clip[]
  quotes         Quote[]

  @@unique([showId, season, episodeNumber])
}

model Clip {
  id         Int          @id @default(autoincrement())
  episodeId  Int
  filePath   String       // path to converted MP4 file
  duration   Int?         // seconds
  startTime  String
  stopTime   String
  episode    Episode      @relation(fields: [episodeId], references: [id])
  quotes     Quote[]
  speakers   ClipSpeaker[]
  keywords   String?  // comma-separated for SQLite; migrate to array in Postgres
}

model Speaker {
  id             Int           @id @default(autoincrement())
  showId         Int
  name           String
  type           String        @default("RECURRING")
  imageUrl       String?
  imagePosition  String?       // CSS object-position, e.g. "center top", "50% 20%"
  show           Show          @relation(fields: [showId], references: [id])
  quotes         Quote[]
  clips          ClipSpeaker[]

  @@unique([showId, name])
}

model Quote {
  id         Int      @id @default(autoincrement())
  episodeId  Int
  clipId     Int
  speakerId  Int?
  text       String
  sequence   Int      // ordering within the clip
  episode    Episode  @relation(fields: [episodeId], references: [id])
  clip       Clip     @relation(fields: [clipId], references: [id])
  speaker    Speaker? @relation(fields: [speakerId], references: [id])

  @@index([clipId, sequence])
  @@index([speakerId])
  @@index([episodeId])
}

model ClipSpeaker {
  clipId     Int
  speakerId  Int
  lineCount  Int     @default(1)
  clip       Clip    @relation(fields: [clipId], references: [id])
  speaker    Speaker @relation(fields: [speakerId], references: [id])

  @@id([clipId, speakerId])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("GUEST")
  createdAt DateTime @default(now())
}

model StagingEpisode {
  id             Int            @id @default(autoincrement())
  showId         Int
  season         Int
  episodeNumber  Int
  title          String
  airDate        DateTime?
  productionCode String?
  basename       String         @unique
  videoPath      String
  quotesPath     String
  status         String         @default("DRAFT")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  show           Show           @relation(fields: [showId], references: [id])
  clips          StagingClip[]
  quotes         StagingQuote[]
}

model StagingClip {
  id               Int            @id @default(autoincrement())
  stagingEpisodeId Int
  index            Int
  startTime        Float
  endTime          Float
  stagingEpisode   StagingEpisode @relation(fields: [stagingEpisodeId], references: [id])
  quotes           StagingQuote[]
}

model StagingQuote {
  id               Int            @id @default(autoincrement())
  stagingEpisodeId Int
  stagingClipId    Int?
  speaker          String
  text             String
  startTime        Float?
  endTime          Float?
  matchMethod      String?
  sequence         Int
  stagingEpisode   StagingEpisode @relation(fields: [stagingEpisodeId], references: [id])
  stagingClip      StagingClip?   @relation(fields: [stagingClipId], references: [id])
}

